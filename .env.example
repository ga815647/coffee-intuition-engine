# Coffee Intuition Engine — 環境設定範例
# 複製成 .env;開發模式可全部留空(離線可跑:記憶體向量庫 + local 雜湊嵌入)

# --- 向量庫後端 ---
# 留空 = 自動偵測:有 CF 金鑰+Vectorize→vectorize;有 Qdrant URL→qdrant;皆無→memory
# 可強制覆寫:memory | qdrant | vectorize
CIE_STORE_BACKEND=

# Qdrant(替代選項):留空 = 記憶體模式;填 URL = Qdrant Cloud
CIE_QDRANT_URL=
CIE_QDRANT_API_KEY=
CIE_COLLECTION=cie_records

# --- 嵌入 ---
# workers_ai(Cloudflare,多語 bge-m3) | local(預設,離線) | openai | voyage
# 雲端 provider 缺金鑰會自動退回 local。
CIE_EMBEDDING_PROVIDER=local
CIE_EMBEDDING_MODEL=
CIE_EMBEDDING_API_KEY=
CIE_EMBEDDING_DIM=256

# --- Cloudflare 原生(建議:Workers AI 嵌入 + Vectorize 向量庫) ---
# 從 Python 走 REST 需下列(Worker binding 部署則不需要):
CIE_CF_ACCOUNT_ID=
CIE_CF_API_TOKEN=
CIE_VECTORIZE_INDEX=cie-records
CIE_WORKERS_AI_EMBED_MODEL=@cf/baai/bge-m3
# 可選:釘住 pooling(mean|cls);留空用伺服器預設。寫入與查詢須一致。
CIE_WORKERS_AI_POOLING=
CIE_CF_TIMEOUT_S=30
CIE_CF_MAX_RETRIES=2

# --- Canonical 真相層(JSONL;向量為衍生物,可從此重嵌重建) ---
# Vectorize 後端務必走 canonical sink,否則「無源」無法重建/換模型。
# 本地路徑(預設);記憶體/Qdrant 後端自存 _canonical,不另寫此檔。
CIE_CANONICAL_PATH=./data/canonical.jsonl
# R2(選配):填 bucket 名 + 上面的 CF 金鑰 → canonical 存 R2 物件(取代本地檔)。
CIE_R2_BUCKET=
CIE_R2_CANONICAL_KEY=canonical.jsonl

# --- Remote MCP(server_http.py;接 claude.ai 自訂連接器才需要) ---
# 兩扇門:公開門(HTTP)= 唯讀,日常 + 分享都走這;私有門(本機 stdio mcp_server.py)
# = owner 唯一寫入,不需任何網路 token。HTTP 上**沒有寫入路徑**(log_calibration 不掛 HTTP)。
# 認證 fail-closed:未設任何 token → 所有 /mcp 請求回 401。stdio 不受影響。
# 產 token:python -c "import secrets; print(secrets.token_urlsafe(32))"
# 主要唯讀 token(日常 + 分享給對方用的連接器 URL 帶這個)。
CIE_MCP_AUTH_TOKEN=
# 額外唯讀 token(選配,供個別發放 / 撤銷):JSON 物件 {token:label} 或陣列 [token]。
# label 僅作稽核標籤,不影響權限(一律唯讀)。例:{"tok_alice":"alice","tok_bob":"bob"}
CIE_MCP_GUEST_TOKENS=
# 監聽位址 / 埠(容器內固定;對外由平台 / 反代映射)。
CIE_MCP_HOST=0.0.0.0
CIE_MCP_PORT=8000
# stateless streamable-http:**必須 1**。每請求自含,認證中介層設的 per-request reader principal
# 才能被工具看到;有狀態模式(0)會讓 principal 退回 owner 預設(can_write=True)→ 瓦解唯讀門
# 防禦縱深,server_http.build_app 啟動時直接 fail-closed 拒絕(見 DESIGN §16.3)。
CIE_MCP_STATELESS=1
# 提醒:remote 部署嵌入器恆 workers_ai、後端用 vectorize(見上 Cloudflare 區塊);
# 別在公開實例用 local 雜湊嵌入(召回品質不足)。

# --- Notion 同步(選配,尚未啟用) ---
CIE_NOTION_TOKEN=
CIE_NOTION_FEEDBACK_DB=
