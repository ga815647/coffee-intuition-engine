# Coffee Intuition Engine — 環境設定範例
# 複製成 .env;開發模式可全部留空(離線可跑:記憶體向量庫 + local 雜湊嵌入)
#
# ┌─ 生產上線 profile(Cloud Run,$0 scale-to-zero;見 DESIGN §14.7)──────────────┐
# │ CIE_STORE_BACKEND=memory          # 記憶體自幹索引(冷啟動從 D1 重建,免外部向量 DB) │
# │ CIE_EMBEDDING_PROVIDER=workers_ai # Workers AI bge-m3(1024 維,多語)              │
# │ CIE_CF_ACCOUNT_ID / CIE_CF_API_TOKEN  # CF token 最小權限:Workers AI:Run + D1:Edit │
# │ CIE_CANONICAL_BACKEND=d1          # 顯式 d1(權威);單一共用真相                     │
# │ CIE_D1_DATABASE_ID=<你的 D1 id>  # wrangler d1 create <name> 後拿到                 │
# │ CIE_MCP_AUTH_TOKEN / CIE_MCP_GUEST_TOKENS  # 認證(fail-closed)                    │
# │ CIE_MCP_STATELESS=1               # 命門,必須 1                                    │
# │ CIE_MCP_PORT 留空                 # Cloud Run 注入 $PORT(8080)                     │
# │ 部署:max-instances=1(單寫者一致性)、min-instances=0(閒置 $0)。                 │
# │ 本機 owner(stdio)用同一份設定 + 同一個 D1 → 寫 global / 晉升,Cloud Run 冷啟動讀到。 │
# └──────────────────────────────────────────────────────────────────────────────┘

# --- 向量庫後端 ---
# 留空 = 自動偵測:有 CF 金鑰+Vectorize→vectorize;有 Qdrant URL→qdrant;皆無→memory
# **生產建議 memory**(記憶體自幹索引 + 冷啟動從 D1 重建;見上方 profile / DESIGN §14.7)。
# 有 CF 金鑰時若不覆寫會自動選 vectorize——上線請顯式設 memory。
# 可強制覆寫:memory | qdrant | vectorize
CIE_STORE_BACKEND=

# Qdrant(替代選項):留空 = 記憶體模式;填 URL = Qdrant Cloud
CIE_QDRANT_URL=
CIE_QDRANT_API_KEY=
CIE_COLLECTION=cie_records

# --- 嵌入 ---
# workers_ai(Cloudflare,多語 bge-m3) | local(預設,離線) | openai | voyage
# 雲端 provider 缺金鑰會自動退回 local。
CIE_EMBEDDING_PROVIDER=local
CIE_EMBEDDING_MODEL=
CIE_EMBEDDING_API_KEY=
CIE_EMBEDDING_DIM=256

# --- Cloudflare 原生(生產:Workers AI 嵌入 + D1 canonical;向量庫走記憶體自幹) ---
# 從 Python 走 REST 需下列。生產 CF API token 最小權限 = **Workers AI:Run + D1:Edit**
# (不需 Vectorize 權限——記憶體後端不用它)。
CIE_CF_ACCOUNT_ID=
CIE_CF_API_TOKEN=
# Vectorize index 名:僅在 CIE_STORE_BACKEND=vectorize 時用;生產記憶體後端可忽略。
CIE_VECTORIZE_INDEX=cie-records
CIE_WORKERS_AI_EMBED_MODEL=@cf/baai/bge-m3
# 可選:釘住 pooling(mean|cls);留空用伺服器預設。寫入與查詢須一致。
CIE_WORKERS_AI_POOLING=
CIE_CF_TIMEOUT_S=30
CIE_CF_MAX_RETRIES=2

# --- Canonical 真相層(向量為衍生物,可從此重嵌重建) ---
# canonical = 單一真相;向量索引隨時可從它重嵌重建(冷啟動 / 換模型 / 災後)。
# 後端自動偵測:顯式 override > d1(金鑰+db_id)> r2(金鑰+bucket)> local(離線預設)。
# 可強制覆寫:local | r2 | d1
CIE_CANONICAL_BACKEND=
# 本地路徑(離線開發預設);記憶體/Qdrant 後端離線時自存 _canonical,不另寫此檔。
CIE_CANONICAL_PATH=./data/canonical.jsonl
# D1(**生產定案**):SQLite-over-HTTP。填 db_id + 上面 CF 金鑰(D1:Edit)→ canonical_backend=d1。
# 逐筆 INSERT OR REPLACE(同 id 後寫者勝),無 R2 整檔 read-modify-write 並發 race。
# 生產記憶體後端的 _canonical 不跨行程(Cloud Run scale-to-zero 即丟),D1 才是
# owner(本機寫 global)與 member(HTTP 寫 self)共用的單一真相;冷啟動從 D1 重建索引。
# 建庫:wrangler d1 create cie-canonical → 把回傳的 database_id 填這裡。
CIE_D1_DATABASE_ID=
# R2(選項;需綁卡啟用 + R2:Edit):填 bucket 名 → canonical_backend=r2。D1 優先於 R2。
CIE_R2_BUCKET=
CIE_R2_CANONICAL_KEY=canonical.jsonl

# --- Remote MCP(server_http.py;接 claude.ai 自訂連接器才需要) ---
# 三層 + 人工晉升:member(HTTP)能寫,但**只寫進自己的 self 命名空間**(grade≤B,寫不到
# global / 他人 ns);owner(本機 stdio mcp_server.py)是唯一能寫 global、唯一能晉升的身分。
# 寫 global / 晉升不需任何網路 token,只在 stdio。
# 認證 fail-closed:未設任何 token → 所有 /mcp 請求回 401。stdio 不受影響。
# 產 token:python -c "import secrets; print(secrets.token_urlsafe(32))"
# 你個人 member token(日常 claude.ai;連接器 URL 帶這個)。解析為 member,寫入強制落你自己的
# self 客製層、grade 上限 B;寫不到 global。
CIE_MCP_AUTH_TOKEN=
# 額外 token(選配,供個別發放 / 撤銷):
#   JSON 物件 {token:user_id} → member,值=寫入命名空間(各寫自己的 self 層、硬隔離彼此);
#   JSON 陣列 [token]         → reader(無命名空間,只讀 global,不可寫)。
#   值為保留字 global / self 會被拒收(fail-closed,防訪客認領 owner 層)。
# 例:{"tok_alice":"alice","tok_bob":"bob"}
CIE_MCP_GUEST_TOKENS=
# 監聽位址 / 埠。CIE_MCP_PORT 留空時用平台注入的 $PORT(Cloud Run=8080),再退回 8000;
# **Cloud Run 請留空**(別硬寫,否則蓋掉 $PORT → 容器監聽錯埠、路由不到)。本機可填 8000。
CIE_MCP_HOST=0.0.0.0
CIE_MCP_PORT=
# stateless streamable-http:**必須 1**。每請求自含,認證中介層設的 per-request member / reader
# principal 才能被工具看到;有狀態模式(0)會讓 principal 退回 owner 預設(可寫 global、不過濾讀)
# → 網路呼叫者繞過 member confinement 寫到 global、讀到所有 self,瓦解三層隔離。
# server_http.build_app 啟動時直接 fail-closed 拒絕(見 DESIGN §16.3)。
CIE_MCP_STATELESS=1
# MCP 傳輸層 DNS-rebinding 防護的 Host allowlist(逗號分隔,支援 ':*' 埠萬用)。**留空 = 關閉**:
# 公開 token-gated 服務的邊界是 fail-closed token 認證 + CORS 鎖 *.claude.ai;DNS rebinding 對公開
# 可路由服務無增益。**且 FastMCP 在 host=127.0.0.1 時會自動開此防護、allowlist 只含 localhost,
# 擋掉雲端 Host → 421 Misdirected Request**;故公開部署留空(server_http 顯式關閉)。綁定固定自有
# 網域時可填(如 cie.example.com,cie.example.com:*)硬化。
CIE_MCP_ALLOWED_HOSTS=
# 提醒:remote 部署嵌入器恆 workers_ai、向量庫用 memory(冷啟動從 D1 重建)、canonical 用 d1;
# 別在公開實例用 local 雜湊嵌入(召回品質不足)。

# --- Notion 同步(選配,尚未啟用) ---
CIE_NOTION_TOKEN=
CIE_NOTION_FEEDBACK_DB=
